{
  "name": "next-step-dance-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/optimize-gallery.mjs && netlify dev",
    "dev:cms": "node scripts/optimize-gallery.mjs && concurrently \"decap-server\" \"netlify dev\"",
    "dev:vite": "vite",
    "predev:vite": "node scripts/optimize-gallery.mjs",
    "optimize:gallery": "node scripts/optimize-gallery.mjs",
    "build": "node scripts/optimize-gallery.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.10.0",
    "framer-motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.76.0",
    "react-router": "^7.15.1",
    "react-use-measure": "^2.1.7",
    "resend": "^6.12.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@netlify/functions": "^5.2.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "decap-server": "^3.7.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "netlify-cli": "^24.11.3",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vitest": "^3.2.4"
  }
}
